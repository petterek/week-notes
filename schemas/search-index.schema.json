{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "version",
    "docs"
  ],
  "properties": {
    "version": {
      "type": "integer"
    },
    "signature": {
      "type": "string",
      "description": "Hash of source data; used to detect staleness."
    },
    "docs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "identifier"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "note",
              "task",
              "meeting",
              "person",
              "company",
              "place",
              "result"
            ]
          },
          "identifier": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "searchText": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        }
      }
    }
  }
}
