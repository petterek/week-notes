{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "key",
      "label"
    ],
    "properties": {
      "key": {
        "type": "string"
      },
      "icon": {
        "type": "string"
      },
      "label": {
        "type": "string"
      },
      "mins": {
        "type": "integer",
        "minimum": 5,
        "description": "Default duration in minutes."
      }
    }
  }
}
