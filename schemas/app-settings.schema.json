{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "vectorSearch": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "model": {
          "type": "string",
          "description": "HF model id, e.g. Xenova/multilingual-e5-base"
        }
      }
    },
    "searchIndex": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "summarization": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "model": {
          "type": "string"
        }
      }
    }
  }
}
