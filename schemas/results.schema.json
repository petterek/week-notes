{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "text",
      "week"
    ],
    "properties": {
      "id": {
        "type": "string"
      },
      "text": {
        "type": "string"
      },
      "week": {
        "type": "string",
        "pattern": "^\\d{4}-W\\d{2}$"
      },
      "people": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "Person key."
        }
      },
      "created": {
        "type": "string",
        "format": "date-time"
      }
    }
  }
}
