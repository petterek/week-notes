{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "contexts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "context"
        ],
        "properties": {
          "context": {
            "type": "string",
            "description": "Context id (folder name under data/)."
          },
          "mePersonKey": {
            "type": "string",
            "description": "Person key in that context to treat as @me."
          }
        }
      }
    }
  }
}
